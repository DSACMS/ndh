            "WY"
          ]
        },
        "specialization": {
          "description": "Specialization within the taxonomy",
          "type": "object",
          "$ref": "#/$defs/taxonomy"
        }
      },
      "required": [
        "type",
        "description",
        "is_primary"
      ]
    }
  },
  "required": [
    "npi",
    "first_name",
    "last_name",
    "addresses"
  ]
}