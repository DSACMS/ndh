{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/provider.schema.json",
  "title": "Provider",
  "description": "A medical professional who provides services",
  "type": "object",
  "properties": {
    "npi": {
      "description": "National provider identifier, which uniquely identifies the provider. NPI must be between 1000000000 and 9999999999",
      "type": "integer",
      "minimum": 1000000000,
      "maximum": 9999999999
    },
    "first_name": {
      "description": "Provider's first name",
      "type": "string"
    },
    "last_name": {
      "description": "Provider's last name",
      "type": "string"
    },
    "middle_name": {
      "description": "Provider's middle name",
      "type": "string"
    },
    "sex": {
      "description": "Provider's sex (e.g. male or female)",
      "enum": [
        "F",
        "M"
      ]
    },
    "name_prefix": {
      "description": "Prefix to a provider's name (e.g. Ms., Mrs., Mr.)",
      "enum": [
        "Ms.",
        "Mr.",
        "Miss",
        "Mrs.",
        "Dr.",
        "Prof."
      ]
    },
    "name_suffix": {
      "description": "Suffix of a provider's name (e.g. Jr., Sr.)",
      "enum": [
        "Jr.",
        "Sr.",
        "I",
        "II",
        "III",
        "IV",
        "V",
        "VI",
        "VII",
        "VIII",
        "IX"
      ]
    },
    "enumeration_date": {
      "description": "The date when the provider received their NPI",
      "type": "string",
      "format": "date"
    },
    "last_updated_date": {
      "description": "The date when the provider record was last updated",
      "type": "string",
      "format": "date"
    },
    "status": {
      "description": "The status of the provider's NPI",
      "enum": []
    },
