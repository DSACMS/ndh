      "description": "Provider taxonomy information",
      "type": "array",
      "items": {
        "$ref": "#/$defs/taxonomy"
      }
    },
    "practice_relationships": {
      "description": "Relationships between providers and provider organizations",
      "type": "object",
      "properties": {
        "provider_organization_npi": {
          "description": "The National Provider Identifier of the provider organization tht the provider has a relationship with",
          "type": "integer",
          "minimum": 1000000000,
          "maximum": 9999999999
        },
        "addresses": {
          "description": "Addresses where the provider practices on behalf of the given provider organization",
          "type": "array",
          "items": {
            "$ref": "address.json"
          }
        },
        "endpoints": {
          "description": "Endpoints associated with the provider based on their relationship with the given provider organization",
          "type": "array",
          "items": {
            "$ref": "endpoints.json"
          }
        }
      }
    }
  },
  "$defs": {
    "taxonomy": {
      "type": "object",
      "properties": {
        "code": {
          "description": "Taxonomy code (from https://taxonomy.nucc.org/)",
          "type": "string"
        },
        "description": {
          "description": "Taxonomy name (from https://taxonomy.nucc.org/)",
          "type": "string"
        },
        "is_primary": {
          "description": "Indicator of whether the taxonomy is the provider's primary taxonomy",
          "type": "boolean"
        },
        "license_number": {
          "description": "License number assigned by a state licensing board, certifying the provider's taxonomy in that state",
          "type": "string"
        },
        "license_date": {
          "description": "The date when the state license was obtained",
          "type": "string",
          "format": "date"
        },
        "state_code": {
          "description": "The state that granted the provider's license for the taxonomy",
          "enum": [
            "AL",
            "AK",
            "AS",
            "AZ",
